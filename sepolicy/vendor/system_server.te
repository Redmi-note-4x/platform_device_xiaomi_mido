get_prop(system_server, userspace_reboot_config_prop)
get_prop(system_server, userspace_reboot_exported_prop)

# power
allow system_server sysfs_battery_supply:file { read open getattr };

# vibrator
allow system_server sysfs_vibrator:file read;

allow system_server unlabeled:dir { add_name create relabelfrom remove_name rename rmdir setattr write };
allow system_server unlabeled:file { append create relabelfrom rename setattr unlink write };
allow system_server unlabeled:sock_file { create setattr unlink };
allow system_server system_file:dir write;
allow system_server vendor_overlay_file:dir write;
allow system_server app_zygote:process getpgid;
allow system_server apexd_prop:file { getattr open };
allow system_server bluetooth_a2dp_offload_prop:file { getattr open };
allow system_server bluetooth_audio_hal_prop:file { getattr open };
allow system_server bluetooth_prop:file { getattr open };
